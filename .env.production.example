APP_VERSION=1.0.4
APP_BIND=0.0.0.0
APP_PORT=3000
HTTPS_PORT=3443

MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
MYSQL_DATABASE=onsite_ops_system
MYSQL_USER=onsite_ops
MYSQL_PASSWORD=replace-with-strong-app-password

INITIAL_ADMIN_PASSWORD=replace-with-admin-password
INITIAL_ENGINEER_PASSWORD=replace-with-engineer-password
INITIAL_ADMIN_SECURITY_QUESTION=管理员安全问题
INITIAL_ADMIN_SECURITY_ANSWER=replace-with-admin-security-answer
INITIAL_ENGINEER_SECURITY_QUESTION=工程师安全问题
INITIAL_ENGINEER_SECURITY_ANSWER=replace-with-engineer-security-answer

ENCRYPTION_KEY=replace-with-at-least-32-chars-random-key
UPGRADE_SIGNING_KEY=replace-with-at-least-32-chars-random-key

SESSION_MAX_AGE_SECONDS=604800
WEB_IDLE_LOGOUT_MINUTES=30
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_LOCK_MS=900000
LOCAL_BACKUP_RETENTION_DAYS=30
AUDIT_ARCHIVE_RETENTION_DAYS=180
MAINTENANCE_INTERVAL_MS=60000
CONFIG_BACKUP_ALLOWED_COMMANDS=show running-config,display current-configuration,show configuration
